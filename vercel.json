{
  "version": 2,
  "name": "mitsuyoshi-saas",
  "builds": [
    {
      "src": "api_server.js",
      "use": "@vercel/node"
    },
    {
      "src": "*.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api_server.js"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
